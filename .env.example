# Supabase Postgres
# Runtime connection used by the Vercel app. Use Supabase Transaction Pooler.
DATABASE_URL="postgresql://APP_ROLE:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1&uselibpqcompat=true"

# Prisma CLI connection used for migrations. Keep this on the direct/session connection.
DIRECT_URL="postgresql://MIGRATION_ROLE:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true"

# Optional: only needed if your migration workflow requires a separate shadow DB.
# SHADOW_DATABASE_URL=""

NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Canonical app domain
NEXT_PUBLIC_APP_URL="https://image.funagent.app"

# OpenAI
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_IMAGE_MODEL="gpt-image-2"

# Optional OpenAI-compatible gateway.
# If XAI_API_KEY is set, image generation uses it before OPENAI_API_KEY.
XAI_API_KEY=""
XAI_BASE_URL="https://api-xai.ainaibahub.com/v1"

# Supabase Edge Function worker trigger.
PROCESS_GENERATION_FUNCTION_URL="https://PROJECT_REF.supabase.co/functions/v1/process-generation"
PROCESS_GENERATION_SECRET="replace-with-a-long-random-secret"

# WeChat Official Account callback
WECHAT_TOKEN="replace-with-a-random-callback-token"
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
ADMIN_OPENIDS=""

# Product limits
DEFAULT_DAILY_LIMIT="3"
DEFAULT_MAX_REF_IMAGES="4"
DEFAULT_MAX_FILE_MB="10"
MAX_TOTAL_UPLOAD_MB="25"

# Storage
BLOB_READ_WRITE_TOKEN=""

# Local-only convenience
ALLOW_DEV_LOGIN="false"
DEV_LOGIN_OPENID="dev-openid"
DEV_LOGIN_ROLE="USER"
